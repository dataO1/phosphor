{
    "name": "Folds",
    "author": "data01",
    "description": "Deep video-feedback kaleidoscope. Warm gold + ivory palette on charcoal. Dual feedback reads at different scales create visible nested spirals. Secondary folding + organic warp break circular symmetry into sharp geometric fragments. Audio-reactive structural rays drive the feedback loop.",
    "shader": "",
    "passes": [
        {
            "name": "main",
            "shader": "folds.wgsl",
            "feedback": true
        }
    ],
    "inputs": [
        {
            "type": "Float",
            "name": "folds",
            "default": 0.4,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "rotation",
            "default": 0.35,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "zoom",
            "default": 0.55,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "complexity",
            "default": 0.45,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "distortion",
            "default": 0.4,
            "min": 0.0,
            "max": 1.0
        }
    ],
    "postprocess": {
        "enabled": true,
        "bloom_threshold": 0.55,
        "bloom_intensity": 0.35,
        "vignette": 0.1
    },
    "audio_mappings": [
        { "feature": "rms", "target": "rotation speed, decay rate" },
        { "feature": "centroid", "target": "rotation offset" },
        { "feature": "flux", "target": "secondary fold mix" },
        { "feature": "bass", "target": "zoom modulation" },
        { "feature": "beat", "target": "centre highlight pulse" },
        { "feature": "onset", "target": "ray push outward" },
        { "feature": "all bands", "target": "ray brightness + width" }
    ]
}
