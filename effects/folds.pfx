{
    "name": "Folds",
    "author": "data01",
    "description": "Intricate feedback kaleidoscope. Classic video-feedback technique: each frame is rotated, scaled, and N-fold mirrored back onto itself. Thin audio-reactive spectral lines feed into the loop, creating endlessly complex sharp geometric mandalas. No particles, no blobs — just transform + feedback + lines.",
    "shader": "",
    "passes": [
        {
            "name": "main",
            "shader": "folds.wgsl",
            "feedback": true
        }
    ],
    "inputs": [
        {
            "type": "Float",
            "name": "folds",
            "default": 0.35,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "rotation",
            "default": 0.4,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "zoom",
            "default": 0.5,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "line_count",
            "default": 0.45,
            "min": 0.0,
            "max": 1.0
        },
        {
            "type": "Float",
            "name": "line_width",
            "default": 0.4,
            "min": 0.0,
            "max": 1.0
        }
    ],
    "postprocess": {
        "enabled": true,
        "bloom_threshold": 0.5,
        "bloom_intensity": 0.4,
        "vignette": 0.1
    },
    "audio_mappings": [
        { "feature": "all bands", "target": "line brightness + width per band" },
        { "feature": "rms", "target": "rotation speed multiplier" },
        { "feature": "centroid", "target": "hue shift + rotation offset" },
        { "feature": "flux", "target": "dynamic fold count modulation" },
        { "feature": "beat", "target": "centre pulse flash" },
        { "feature": "onset", "target": "line push outward" },
        { "feature": "bass", "target": "zoom modulation" }
    ]
}
